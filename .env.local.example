INVESTIGATION_SECRET_KEY=local-dev-secret
INVESTIGATION_BOOTSTRAP_ADMIN_ALIASES=poirot
INVESTIGATION_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
INVESTIGATION_SECURE_COOKIES=false
INVESTIGATION_RATE_LIMITS_ENABLED=false

# Leave INVESTIGATION_DATABASE_URL unset locally to use SQLite.
INVESTIGATION_DB_PATH=backend/data/investigation_room.db
INVESTIGATION_CASES_PATH=cases
INVESTIGATION_SEED_CASES_ON_START=true

INVESTIGATION_AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_TIMEOUT_SECONDS=90
OLLAMA_STREAM_TIMEOUT_SECONDS=120

# To test Gemini locally instead, set INVESTIGATION_AI_PROVIDER=gemini and add a key.
GEMINI_API_KEY=
